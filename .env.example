# Copy this file to `.env.local` and fill in your Supabase project values.
# These are exposed to the browser by Vite, so use the *anon* (public) key only.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Name of the Supabase Storage bucket used for complaint photos.
VITE_SUPABASE_BUCKET=complaint-photos
